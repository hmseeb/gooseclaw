# gooseclaw environment variables
# copy to .env for local docker testing, or set in Railway dashboard

# ─── LLM Provider (pick ONE) ───────────────────────────────────────────────

# Option A: Claude subscription (best experience, no API costs)
# Run `claude setup-token` locally, paste the token here
# CLAUDE_SETUP_TOKEN=sk-ant-oat01-...

# Option B: API key (pay-per-use)
# GOOSE_PROVIDER=anthropic
# GOOSE_API_KEY=sk-ant-api03-...

# Option C: Custom provider (self-hosted or corporate)
# CUSTOM_PROVIDER_URL=https://my-llm.corp.com/v1
# CUSTOM_PROVIDER_MODEL=gpt-4
# CUSTOM_PROVIDER_KEY=

# Model override (optional, works with any provider)
# GOOSE_MODEL=claude-sonnet-4-20250514

# ─── Telegram ──────────────────────────────────────────────────────────────

# Create a bot with @BotFather on Telegram, paste the token
TELEGRAM_BOT_TOKEN=

# ─── Git Persistence (optional) ────────────────────────────────────────────

# Auto-push identity changes (memory.md, journal/) to GitHub
# GITHUB_PAT=ghp_...
# GITHUB_REPO=username/my-agent

# ─── Web UI ──────────────────────────────────────────────────────────────

# Auth token for web interface (auto-generated if not set)
# Set this to keep a stable token across redeploys
# GOOSE_WEB_AUTH_TOKEN=your-secret-token-here

# ─── Config ────────────────────────────────────────────────────────────────

# Timezone (for scheduled tasks)
TZ=UTC
