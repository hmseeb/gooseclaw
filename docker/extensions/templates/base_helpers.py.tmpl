def _vault_get(key):
    """Read a credential from the vault at runtime. Never hardcoded."""
    result = subprocess.run(
        ["secret", "get", key],
        capture_output=True,
        text=True,
    )
    if result.returncode != 0:
        raise RuntimeError(
            f"Vault key not found: {key} (exit {result.returncode}): {result.stderr.strip()}"
        )
    return result.stdout.strip()


